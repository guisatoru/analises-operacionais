# Copie este arquivo para .env e preencha com seus valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# Chave secreta do Django (gere uma nova para produção).
SECRET_KEY=troque-isso-por-uma-chave-secreta-real

# Coloque False em produção.
DEBUG=True

# Hosts permitidos, separados por vírgula. Use * apenas em desenvolvimento.
ALLOWED_HOSTS=*

# Origens HTTPS confiáveis para formulários POST (login, logout e importações).
# Exemplo: https://seu-endereco.trycloudflare.com
CSRF_TRUSTED_ORIGINS=

# Quando True, o login expira ao fechar o navegador.
SESSION_EXPIRE_AT_BROWSER_CLOSE=True

# Caminho personalizado para o banco de dados SQLite (opcional).
# Útil para colocar o banco de dados em um disco de rede (como o disco F).
# Exemplo: SQLITE_PATH=F:\caminho\para\pasta\db.sqlite3
SQLITE_PATH=
GEOVICTORIA_USER=
GEOVICTORIA_PASSWORD=

# Configurações de envio de E-mail (Exemplo para o Resend)
# Deixe EMAIL_BACKEND vazio ou com o valor abaixo para exibir no console em ambiente local.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=sua_api_key_do_resend
# DEFAULT_FROM_EMAIL=onboarding@resend.dev

# URL do Frontend React
FRONTEND_URL=http://localhost:5173

