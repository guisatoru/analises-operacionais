# Copie este arquivo para .env e preencha com seus valores reais.
# O .env nunca deve ser commitado (já está no .gitignore).

# Chave secreta do Django (gere uma nova para produção).
SECRET_KEY=troque-isso-por-uma-chave-secreta-real

# Coloque False em produção.
DEBUG=True

# Hosts permitidos, separados por vírgula. Use * apenas em desenvolvimento.
ALLOWED_HOSTS=*